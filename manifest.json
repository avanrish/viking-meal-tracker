{
  "manifest_version": 3,
  "name": "Viking Meal Tracker",
  "version": "1.0.0",
  "description": "Rate and track meals from Kuchnia Vikinga directly on the dashboard",
  "permissions": ["storage"],
  "host_permissions": ["*://*.kuchniavikinga.pl/*"],
  "content_scripts": [
    {
      "matches": ["*://*.kuchniavikinga.pl/*"],
      "js": ["lib/storage.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
